# Copy to terraform.tfvars and fill in real values. Never commit terraform.tfvars.

my_ip_cidr     = "203.0.113.10/32" # your current public IP, find via: curl -s https://checkip.amazonaws.com
key_pair_name  = "your-existing-key-pair-name"

# Everything else (vpc_cidr, subnet CIDRs, azs, nat_gateway_az_index) has
# sensible defaults in variables.tf - override here only if you want
# different values than the lab's standard plan.

